# ============================================
# Appie Kit — Environment Variables
# ============================================
# Copy this to .env.secrets and fill in your values.
# NEVER commit .env.secrets to git!
# Set permissions: chmod 600 .env.secrets
# ============================================

# === REQUIRED ===

# Anthropic API key (Claude) — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === MESSAGING (pick one or more) ===

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Discord bot token — get from https://discord.com/developers
DISCORD_BOT_TOKEN=

# === OPTIONAL: Email ===

# Brevo (SendInBlue) — get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# === OPTIONAL: CRM ===

# Airtable — get from https://airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# === OPTIONAL: Search ===

# Brave Search — get from https://api.search.brave.com
BRAVE_API_KEY=

# Exa (AI search) — get from https://exa.ai
EXA_API_KEY=

# === OPTIONAL: AI Models ===

# OpenAI (for embeddings, GPT fallback)
OPENAI_API_KEY=

# OpenRouter (multi-model fallback)
OPENROUTER_API_KEY=

# === OPTIONAL: Voice & Video ===

# ElevenLabs (TTS) — get from https://elevenlabs.io
ELEVENLABS_API_KEY=

# fal.ai (video generation) — get from https://fal.ai/dashboard
FAL_KEY=

# === OPTIONAL: Infrastructure ===

# Namecheap (domain management)
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=

# Vercel (deployments)
VERCEL_TOKEN=

# DigitalOcean
DO_API_TOKEN=

# === OPTIONAL: Google Workspace ===

# Google OAuth (for Gmail, Calendar, Drive)
# See: https://docs.openclaw.ai/skills/gws
# GOG_KEYRING_PASSWORD=

# === OPTIONAL: Memory ===

# Pinecone (vector memory)
PINECONE_API_KEY=
PINECONE_INDEX=

# Supermemory
SUPERMEMORY_API_KEY=
